{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "api/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "api/**/*.test.ts", "node_modules", "dist"]
}
