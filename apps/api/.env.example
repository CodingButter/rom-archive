# TheGamesDB (TGDB) API key — primary game-metadata source.
# Keyed, hard ~1000 requests/month budget. The metadata service is caching-first
# and falls back to keyless libretro identification when this is unset, so the
# app degrades gracefully rather than erroring without a key.
#
# Read only from process.env.TGDB_API_KEY — never hardcode it in source.
# If this key is ever leaked, rotate it in the TGDB account and update the value
# in the deployment environment (Vercel project env vars).
TGDB_API_KEY=
